{
  "private": true,
  "name": "dartsmate",
  "productName": "DartsMate",
  "description": "Analyze, track and compare your dart games.",
  "version": "0.6.2",
  "author": "DartsMate Contributors",
  "main": "app/background.js",
  "repository": "https://github.com/timderes/dartsmate",
  "scripts": {
    "dev": "nextron",
    "build": "nextron build --publish never",
    "build:all": "nextron build --all --publish never",
    "build:win32": "nextron build --win --ia32 --publish never",
    "build:win64": "nextron build --win --x64 --publish never",
    "build:mac": "nextron build --mac --x64 --publish never",
    "build:linux": "nextron build --linux --publish never",
    "postinstall": "electron-builder install-app-deps",
    "lint": "concurrently --kill-others-on-fail --names \"MAIN,RENDERER\" --prefix-colors \"blue,magenta\" \"npm:lint:main\" \"npm:lint:renderer\"",
    "lint:main": "eslint . --ignore-pattern renderer --max-warnings 0",
    "lint:renderer": "eslint renderer --max-warnings 0",
    "lint:fix": "npm run lint:main -- --fix && npm run lint:renderer -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck:renderer": "tsc --noEmit -p renderer/tsconfig.json",
    "typecheck:main": "echo \"TODO: implement main process typecheck\" && exit 0",
    "typecheck": "concurrently --kill-others-on-fail --names \"MAIN,RENDERER\" --prefix-colors \"blue,magenta\" \"npm:typecheck:main\" \"npm:typecheck:renderer\"",
    "release": "electron-builder --publish always",
    "test": "vitest"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mantine/charts": "^9.2.0",
    "@mantine/core": "^9.2.0",
    "@mantine/dropzone": "^9.2.0",
    "@mantine/form": "^9.2.0",
    "@mantine/hooks": "^9.2.0",
    "@mantine/modals": "^9.2.0",
    "@mantine/notifications": "^9.2.0",
    "@tabler/icons-react": "^3.40.0",
    "electron-log": "^5.4.3",
    "electron-serve": "^3.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@workmate/country-and-currency": "^1.2.2",
    "concurrently": "^9.2.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-barrel-files": "^1.2.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next": "^16.1.6",
    "next-i18next": "^15.4.3",
    "nextron": "^9.5.0",
    "postcss": "^8.5.5",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "3.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-image-file-resizer": "^0.4.8",
    "recharts": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "use-elapsed-time": "^3.0.4",
    "uuid": "^13.0.0",
    "vitest": "^4.1.2"
  }
}
