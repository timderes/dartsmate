{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/contexts/*": ["./contexts/*"],
      "@/hooks/*": ["./hooks/*"],
      "@/lib/*": ["./lib/*"],
      "@/styles/*": ["./styles/*"],
      "@/tests/*": ["./tests/*"],
      "@/utils/*": ["./utils/*"]
    }
  },
  "extends": "../tsconfig.json",
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../main/**/*.ts",
    "../main/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
